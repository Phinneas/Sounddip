---
// JsonLd — Renders a <script type="application/ld+json"> tag for Schema.org structured data.
// Pass a plain JS object; it gets serialized to JSON and injected into the page head.

interface Props {
  data: Record<string, any>;
}
const { data } = Astro.props;
---

<script type="application/ld+json" set:html={JSON.stringify(data)} />
