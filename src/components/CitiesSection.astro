---
// CitiesSection — city cards + overflow pills
// V1 design, italic serif pills, warm overlay

const cities = [
  { num: "01 · East Coast", name: "New", nameItalic: "York", count: "47 sessions this week", img: "https://images.stockcake.com/public/3/4/6/346ed7ec-2f7d-4dd2-a744-572f9cfcbd96_large/historic-brick-townhouses-stockcake.jpg", alt: "Brooklyn brownstones", href: "/cities/new-york" },
  { num: "02 · Mojave", name: "Joshua", nameItalic: "Tree", count: "11 sessions this week", img: "https://sound-bath.com/wp-content/uploads/2025/11/The-Gong-Room-Joshua-Tree.jpeg", alt: "Joshua Tree gong room", href: "/cities/joshua-tree" },
  { num: "03 · California", name: "Los", nameItalic: "Angeles", count: "20 sessions this week", img: "https://images.stockcake.com/public/3/4/6/346ed7ec-2f7d-4dd2-a744-572f9cfcbd96_large/historic-brick-townhouses-stockcake.jpg", alt: "Los Angeles at dusk", href: "/cities/los-angeles" },
];

const overflow = [
  { name: "Chicago", count: 22, href: "/cities/chicago" },
  { name: "Austin", count: 14, href: "/cities/austin" },
  { name: "San Francisco", count: 10, href: "/cities/san-francisco" },
  { name: "Denver", count: 16, href: "/cities/denver" },
  { name: "Seattle", count: 19, href: "/cities/seattle" },
  { name: "Portland", count: 19, href: "/cities/portland" },
  { name: "Sedona", count: 8, href: "/cities/sedona" },
  { name: "Boulder", count: 7, href: "/cities/boulder" },
  { name: "Asheville", count: 7, href: "/cities/asheville" },
  { name: "Miami", count: 9, href: "/cities/miami" },
  { name: "San Diego", count: 8, href: "/cities/san-diego" },
  { name: "Boston", count: 5, href: "/cities/boston" },
  { name: "Santa Fe", count: 7, href: "/cities/santa-fe" },
  { name: "Minneapolis", count: 8, href: "/cities/minneapolis" },
  { name: "Washington DC", count: 7, href: "/cities/washington-dc" },
  { name: "New Orleans", count: 5, href: "/cities/new-orleans" },
  { name: "Burlington", count: 7, href: "/cities/burlington" },
];
---

<section class="section">
  <div class="section-head">
    <div class="section-num">iii.</div>
    <div class="section-title">Where to <em>drift.</em></div>
    <div class="section-meta">
      <strong>20 cities</strong>
      and growing
    </div>
  </div>
  <p class="section-lede">Sound Dip is biggest in New York and Joshua Tree, but we cover twenty cities in total. Pick a destination — or browse for one.</p>

  <div class="cities-grid">
    {cities.map((c) => (
      <a class="city" href={c.href ?? undefined} style={c.href ? '' : 'pointer-events:none'}>
        <img src={c.img} alt={c.alt} loading="lazy" />
        <div class="city-info">
          <div class="city-num">{c.num}</div>
          <div class="city-name">{c.name} <em>{c.nameItalic}</em></div>
          <div class="city-count">{c.count}</div>
        </div>
      </a>
    ))}
  </div>

  <div class="cities-overflow">
    <span class="cities-overflow-label">Also in</span>
    {overflow.map((c) => (
      <a class="city-pill" href={c.href}>
        {c.name} <span class="count">{c.count}</span>
      </a>
    ))}
  </div>
</section>

<style>
  .cities-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-bottom: 60px;
  }
  .city {
    position: relative;
    aspect-ratio: 3/4;
    border-radius: 6px;
    overflow: hidden;
    cursor: pointer;
    box-shadow: var(--shadow);
    transition: transform 0.35s ease;
  }
  .city:hover { transform: translateY(-4px); }
  .city img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 1.4s ease;
  }
  .city:hover img { transform: scale(1.06); }
  .city::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 30%, rgba(34,27,19,0.1) 60%, rgba(34,27,19,0.7) 100%);
  }
  .city-info {
    position: absolute;
    bottom: 32px; left: 32px; right: 32px;
    z-index: 2;
    color: var(--bone);
  }
  .city-num {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--bone);
    opacity: 0.7;
    margin-bottom: 8px;
  }
  .city-name {
    font-family: var(--serif);
    font-weight: 300;
    font-size: 48px;
    line-height: 0.92;
    letter-spacing: -1.5px;
    margin-bottom: 10px;
    font-variation-settings: "opsz" 144;
  }
  .city-name em { font-style: italic; }
  .city-count {
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    color: var(--bone);
    opacity: 0.85;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-variation-settings: "opsz" 72;
  }
  .city-count::after { content: "→"; font-family: var(--sans); font-style: normal; font-size: 16px; }

  /* Overflow pills */
  .cities-overflow {
    padding-top: 36px;
    border-top: 1px solid var(--rule);
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: baseline;
  }
  .cities-overflow-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-right: 12px;
    padding: 10px 0;
  }
  .city-pill {
    padding: 10px 18px;
    border: 1px solid var(--rule);
    border-radius: 100px;
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    color: var(--ink);
    cursor: pointer;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--bone);
    font-variation-settings: "opsz" 72;
  }
  .city-pill .count {
    font-family: var(--mono);
    font-style: normal;
    font-size: 10px;
    letter-spacing: 1px;
    color: var(--ink-soft);
  }
  .city-pill:hover {
    background: var(--linen);
    border-color: var(--clay);
    color: var(--clay);
  }
  .city-pill { text-decoration: none; }
  a.city { text-decoration: none; }

  @media (max-width: 1024px) {
    .cities-grid { grid-template-columns: 1fr; }
  }
</style>
