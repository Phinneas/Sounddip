---
// Hero — V1 split layout (left type, right photo)
// Improvements applied:
//   • "Now Bathing" widget moved inside hero bottom-left (V2 placement)
//   • Hero-meta stat block replaced with urgent city/session copy + CTA pill (scrolls to Dip Bar)
//   • Clear primary action above the fold
---

<section class="hero">
  <div class="hero-inner">

    <!-- LEFT: Text -->
    <div class="hero-text">
      <div class="hero-eyebrow">An index of sound · est. 2026</div>
      <h1>Find a<br>sound <em>bath.</em></h1>
      <p class="hero-sub">A small, considered directory of sound bath sessions, vetted practitioners, and the rooms that hold them.</p>

      <!-- Improved: urgent copy + clear CTA instead of raw stats -->
      <div class="hero-action">
        <p class="hero-urgency"><strong>47 sessions</strong> in New York tonight</p>
        <a href="#dip-bar" class="hero-cta">Find a session tonight</a>
      </div>
    </div>

    <!-- RIGHT: Photo -->
    <div class="hero-photo-wrap">
      <img
        src="https://sound-bath.com/wp-content/uploads/2025/11/The-Gong-Room-Joshua-Tree-1.jpeg"
        alt="The Gong Room in Joshua Tree"
        loading="eager"
      />
      <div class="hero-caption">
        <span class="place">The Gong Room</span>
        <span>Joshua Tree, May</span>
      </div>

      <!-- Now Bathing widget — improved placement: inside hero, bottom-left (V2) -->
      <div class="now-bathing">
        <div class="live-dot"></div>
        <div>
          <div class="now-bathing-label">Now bathing · 8:14 PM EST</div>
          <div class="now-bathing-body">A <strong>Crystal Bowl Circle</strong> with Maya Sundara — Greenpoint, Brooklyn</div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    max-width: 1440px;
    margin: 0 auto;
    padding: 140px 6vw 80px;
  }
  .hero-eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: 36px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .hero-eyebrow::before {
    content: "";
    width: 30px; height: 1px;
    background: var(--clay);
    opacity: 0.5;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 80px;
    align-items: end;
  }
  .hero-text h1 {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(72px, 9.5vw, 168px);
    line-height: 0.9;
    letter-spacing: -4px;
    color: var(--ink);
    font-variation-settings: "opsz" 144;
    margin-bottom: 32px;
  }
  .hero-text h1 em {
    font-style: italic;
    color: var(--clay);
  }
  .hero-sub {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: 22px;
    color: var(--ink-mid);
    line-height: 1.4;
    max-width: 460px;
    margin-bottom: 44px;
  }

  /* Improved: CTA block replaces raw stat block */
  .hero-action {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .hero-urgency {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .hero-urgency strong { color: var(--ink); font-weight: 500; }
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: var(--ink);
    color: var(--bone);
    text-decoration: none;
    border-radius: 100px;
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.2px;
    width: fit-content;
    transition: background 0.2s;
  }
  .hero-cta::after { content: "→"; }
  .hero-cta:hover { background: var(--clay); }

  /* Photo */
  .hero-photo-wrap {
    position: relative;
    aspect-ratio: 4/5;
    overflow: hidden;
    border-radius: 4px;
    box-shadow: var(--shadow);
  }
  .hero-photo-wrap img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 12s ease-out;
  }
  .hero-photo-wrap:hover img { transform: scale(1.04); }

  .hero-caption {
    position: absolute;
    bottom: 120px; left: 24px; right: 24px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--bone);
  }
  .hero-caption .place {
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    text-transform: none;
    letter-spacing: -0.3px;
  }

  /* Now Bathing — inside photo, bottom-left (V2 placement, V1 palette) */
  .now-bathing {
    position: absolute;
    bottom: 24px; left: 24px; right: 24px;
    background: rgba(244, 237, 224, 0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--rule);
    border-radius: 12px;
    padding: 14px 18px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .live-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--clay);
    flex-shrink: 0;
    animation: pulse 2.4s infinite;
  }
  .now-bathing-label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: 3px;
  }
  .now-bathing-body {
    font-family: var(--serif);
    font-style: italic;
    font-size: 14px;
    color: var(--ink);
    line-height: 1.3;
  }
  .now-bathing-body strong {
    font-weight: 400;
    color: var(--ink);
  }

  @media (max-width: 1024px) {
    .hero-inner { grid-template-columns: 1fr; gap: 48px; }
    .hero-text h1 { font-size: clamp(60px, 14vw, 100px); }
    .hero-photo-wrap { aspect-ratio: 4/3; }
  }
</style>
