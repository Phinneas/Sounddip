---
interface Props {
  name: string;
  note: string;
  index: number;
}
const { name, note, index } = Astro.props;
const num = String(index + 1).padStart(2, '0');
---

<div class="venue-card">
  <div class="venue-num">{num}</div>
  <div class="venue-body">
    <div class="venue-name">{name}</div>
    <p class="venue-note">{note}</p>
  </div>
  <a href="#" class="venue-cta" aria-label={`View sessions at ${name}`}>
    <span>Sessions</span>
    <span class="arrow">→</span>
  </a>
</div>

<style>
  .venue-card {
    display: grid;
    grid-template-columns: 48px 1fr auto;
    gap: 24px;
    align-items: start;
    padding: 28px 0;
    border-bottom: 1px solid var(--rule-soft);
  }
  .venue-card:first-child { border-top: 1px solid var(--rule-soft); }

  .venue-num {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: 28px;
    color: var(--clay);
    line-height: 1;
    padding-top: 4px;
  }

  .venue-name {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 22px;
    color: var(--ink);
    letter-spacing: -0.3px;
    margin-bottom: 10px;
    font-variation-settings: "opsz" 72;
  }

  .venue-note {
    font-family: var(--sans);
    font-size: 15px;
    color: var(--ink-mid);
    line-height: 1.6;
    max-width: 640px;
  }

  .venue-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--ink-soft);
    text-decoration: none;
    padding-top: 6px;
    white-space: nowrap;
    transition: color 0.2s;
  }
  .venue-cta:hover { color: var(--clay); }
  .venue-cta:hover .arrow { transform: translateX(4px); }

  .arrow {
    font-family: var(--sans);
    font-size: 14px;
    transition: transform 0.2s ease;
    display: inline-block;
  }

  @media (max-width: 640px) {
    .venue-card { grid-template-columns: 40px 1fr; }
    .venue-cta { display: none; }
  }
</style>
