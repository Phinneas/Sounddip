---
// MapSection — warm SVG map (V1) + listings with optional avatars (V2 import)
// Improvements:
//   • Listing rows now include a 52×52 circle avatar (practitioner photo or monogram fallback)
//   • Fallback: linen circle with italic Fraunces initial when no photo provided

interface Listing {
  modality: string;
  duration: string;
  title: string;
  practitioner: string;
  location: string;
  time: string;
  price: string;
  priceNote?: string;
  featured?: boolean;
  avatarSrc?: string;
}

const listings: Listing[] = [
  { modality: "Crystal bowls", duration: "75 min", title: "Tide Pool Sound Circle", practitioner: "Maya Sundara", location: "Greenpoint, Brooklyn", time: "Tonight, 8:00", price: "$42", priceNote: "sliding" },
  { modality: "Gong bath", duration: "90 min", title: "Resonance Ceremony", practitioner: "Theo Ash", location: "Bushwick", time: "Tomorrow, 7:00", price: "$58" },
  { modality: "Brass", duration: "60 min", title: "Tibetan Bowl Healing", practitioner: "Indra Vale", location: "West Village", time: "Sat 5/30, 6:30", price: "$50", featured: true },
  { modality: "Outdoor · Dawn", duration: "120 min", title: "Forest Bath at First Light", practitioner: "Aurelia Moon", location: "Bear Mountain, NY", time: "Sun 5/31, 6:00", price: "$75" },
  { modality: "Crystal bowls", duration: "60 min", title: "Lunar Bowl Bath", practitioner: "Rae Voss", location: "Williamsburg", time: "Mon 6/1, 8:00", price: "$38" },
  { modality: "Voice + bowl", duration: "75 min", title: "A Slow Evening", practitioner: "Othmar Lee", location: "Park Slope", time: "Tue 6/2, 7:30", price: "$45" },
];
---

<section class="section">
  <div class="section-head">
    <div class="section-num">i.</div>
    <div class="section-title">Sessions <em>near you.</em></div>
    <div class="section-meta">
      <strong>47 sessions</strong>
      within 10 mi of Greenpoint
    </div>
  </div>
  <p class="section-lede">All forty-seven sessions this week, mapped and listed, sorted by soonest. Hold a name to read more about a practitioner.</p>

  <div class="map-grid">

    <!-- MAP -->
    <div class="map-frame">
      <div class="map-top">
        <div class="map-city">New York</div>
        <div class="map-toggle">
          <button class="active">Map</button>
          <button>List</button>
        </div>
      </div>

      <svg class="map-svg" viewBox="0 0 800 800" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <radialGradient id="glow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#b8704a" stop-opacity="0.25"/>
            <stop offset="100%" stop-color="#b8704a" stop-opacity="0"/>
          </radialGradient>
        </defs>
        <rect width="800" height="800" fill="#ece3d1"/>
        <!-- Hudson River -->
        <path d="M -20 0 Q 60 200, 50 420 T 110 800 L -20 800 Z" fill="#f4ede0" opacity="0.95"/>
        <!-- East River -->
        <path d="M 620 0 Q 580 180, 605 380 T 555 800 L 820 800 L 820 0 Z" fill="#f4ede0" opacity="0.95"/>
        <!-- Water ripples -->
        <g stroke="#c4b292" stroke-width="0.6" fill="none" opacity="0.5">
          <path d="M 25 100 Q 60 96, 90 102"/><path d="M 30 220 Q 65 216, 95 222"/>
          <path d="M 22 340 Q 60 336, 90 342"/><path d="M 32 460 Q 65 456, 95 462"/>
          <path d="M 25 580 Q 60 576, 90 582"/><path d="M 30 700 Q 65 696, 95 702"/>
          <path d="M 660 90 Q 690 86, 720 92"/><path d="M 670 200 Q 700 196, 730 202"/>
          <path d="M 665 310 Q 695 306, 725 312"/><path d="M 670 420 Q 700 416, 730 422"/>
          <path d="M 660 530 Q 690 526, 720 532"/><path d="M 670 640 Q 700 636, 730 642"/>
        </g>
        <!-- Manhattan -->
        <g opacity="0.95">
          <rect x="160" y="560" width="380" height="180" fill="#d9c8a8"/>
          <rect x="190" y="60" width="380" height="500" fill="#d9c8a8"/>
          <g stroke="#c4b292" stroke-width="1" opacity="0.6">
            <line x1="190" y1="140" x2="570" y2="140"/><line x1="190" y1="220" x2="570" y2="220"/>
            <line x1="190" y1="300" x2="570" y2="300"/><line x1="190" y1="380" x2="570" y2="380"/>
            <line x1="190" y1="460" x2="570" y2="460"/><line x1="290" y1="60" x2="290" y2="560"/>
            <line x1="390" y1="60" x2="390" y2="560"/><line x1="490" y1="60" x2="490" y2="560"/>
          </g>
          <!-- Central Park -->
          <rect x="300" y="180" width="180" height="100" fill="#a8a07a" opacity="0.5"/>
          <text x="390" y="234" fill="#6e6b4a" font-family="Fraunces, serif" font-style="italic" font-size="12" text-anchor="middle" opacity="0.7">the park</text>
        </g>
        <!-- Brooklyn -->
        <g opacity="0.95">
          <rect x="555" y="500" width="265" height="300" fill="#d9c8a8"/>
          <g stroke="#c4b292" stroke-width="1" opacity="0.6">
            <line x1="555" y1="600" x2="820" y2="600"/><line x1="555" y1="700" x2="820" y2="700"/>
            <line x1="650" y1="500" x2="650" y2="800"/><line x1="740" y1="500" x2="740" y2="800"/>
          </g>
        </g>
        <!-- Labels -->
        <text x="380" y="430" fill="#8a7d6e" font-family="Fraunces, serif" font-style="italic" font-size="13" text-anchor="middle" opacity="0.75">Manhattan</text>
        <text x="690" y="670" fill="#8a7d6e" font-family="Fraunces, serif" font-style="italic" font-size="13" text-anchor="middle" opacity="0.75">Brooklyn</text>
        <text x="55" y="400" fill="#b8704a" font-family="JetBrains Mono, monospace" font-size="9" text-anchor="middle" opacity="0.7" letter-spacing="1.5">HUDSON R.</text>
        <text x="760" y="350" fill="#b8704a" font-family="JetBrains Mono, monospace" font-size="9" text-anchor="middle" opacity="0.7" letter-spacing="1.5">EAST R.</text>
        <!-- Bridge -->
        <line x1="555" y1="700" x2="640" y2="660" stroke="#8d6431" stroke-width="1.2" opacity="0.45" stroke-dasharray="2,3"/>
        <!-- Pins -->
        <g><circle cx="620" cy="500" r="22" fill="url(#glow)"/><circle class="pin-pulse" cx="620" cy="500" r="4" fill="#b8704a" opacity="0.6"/><circle cx="620" cy="500" r="5" fill="#b8704a"/><circle cx="620" cy="500" r="2" fill="#f4ede0"/></g>
        <g><circle cx="720" cy="600" r="22" fill="url(#glow)"/><circle class="pin-pulse pin-pulse-2" cx="720" cy="600" r="4" fill="#b8704a" opacity="0.6"/><circle cx="720" cy="600" r="5" fill="#b8704a"/><circle cx="720" cy="600" r="2" fill="#f4ede0"/></g>
        <g><circle cx="270" cy="400" r="22" fill="url(#glow)"/><circle class="pin-pulse pin-pulse-3" cx="270" cy="400" r="4" fill="#b8704a" opacity="0.6"/><circle cx="270" cy="400" r="5" fill="#b8704a"/><circle cx="270" cy="400" r="2" fill="#f4ede0"/></g>
        <g><circle cx="650" cy="540" r="22" fill="url(#glow)"/><circle class="pin-pulse pin-pulse-4" cx="650" cy="540" r="4" fill="#b8704a" opacity="0.6"/><circle cx="650" cy="540" r="5" fill="#b8704a"/><circle cx="650" cy="540" r="2" fill="#f4ede0"/></g>
        <g><circle cx="305" cy="360" r="22" fill="url(#glow)"/><circle class="pin-pulse pin-pulse-5" cx="305" cy="360" r="4" fill="#b8704a" opacity="0.6"/><circle cx="305" cy="360" r="5" fill="#b8704a"/><circle cx="305" cy="360" r="2" fill="#f4ede0"/></g>
        <g><circle cx="335" cy="510" r="22" fill="url(#glow)"/><circle cx="335" cy="510" r="5" fill="#b8704a"/><circle cx="335" cy="510" r="2" fill="#f4ede0"/></g>
        <g><circle cx="280" cy="220" r="22" fill="url(#glow)"/><circle cx="280" cy="220" r="5" fill="#b8704a"/><circle cx="280" cy="220" r="2" fill="#f4ede0"/></g>
        <g><circle cx="390" cy="120" r="22" fill="url(#glow)"/><circle cx="390" cy="120" r="5" fill="#b8704a"/><circle cx="390" cy="120" r="2" fill="#f4ede0"/></g>
        <!-- Distant pins -->
        <circle cx="470" cy="80" r="3" fill="#b8704a" opacity="0.55"/>
        <circle cx="520" cy="240" r="3" fill="#b8704a" opacity="0.55"/>
        <circle cx="225" cy="300" r="3" fill="#b8704a" opacity="0.55"/>
        <circle cx="365" cy="450" r="3" fill="#b8704a" opacity="0.55"/>
        <circle cx="510" cy="400" r="3" fill="#b8704a" opacity="0.55"/>
        <circle cx="660" cy="700" r="3" fill="#b8704a" opacity="0.55"/>
      </svg>

      <div class="map-bottom">
        <div class="map-chip active">All · 47</div>
        <div class="map-chip">Crystal · 18</div>
        <div class="map-chip">Gong · 14</div>
        <div class="map-chip">Brass · 9</div>
        <div class="map-chip">Voice · 6</div>
      </div>
    </div>

    <!-- LISTINGS -->
    <div>
      <div class="listings-head">
        <div class="listings-count"><strong>10 of 47</strong> showing</div>
        <button class="listings-sort">Soonest</button>
      </div>
      <div class="listings">
        {listings.map((l) => (
          <div class="listing">
            <!-- Avatar: V2 import — circle photo or monogram fallback -->
            <div class="listing-avatar">
              {l.avatarSrc
                ? <img src={l.avatarSrc} alt={l.practitioner} />
                : <span class="avatar-initial">{l.practitioner[0]}</span>
              }
            </div>
            <div class="listing-body">
              <div class="listing-modality">
                <span>{l.modality}</span>
                <span>{l.duration}</span>
                {l.featured && <span class="featured-tag">Featured</span>}
              </div>
              <div class="listing-title">{l.title}</div>
              <div class="listing-by">with <strong>{l.practitioner}</strong>, in {l.location}</div>
            </div>
            <div class="listing-right">
              <div class="listing-arrow">→</div>
              <div class="listing-time">{l.time}</div>
              <div class="listing-price">
                <strong>{l.price}</strong>
                {l.priceNote && ` · ${l.priceNote}`}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .map-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 56px;
    align-items: start;
  }

  /* Map */
  .map-frame {
    position: relative;
    background: var(--linen);
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--rule-soft);
    aspect-ratio: 1/1;
  }
  .map-svg { width: 100%; height: 100%; display: block; }
  .map-top {
    position: absolute;
    top: 22px; left: 22px; right: 22px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 2;
  }
  .map-city {
    font-family: var(--serif);
    font-style: italic;
    font-size: 20px;
    color: var(--ink);
    background: var(--bone);
    padding: 7px 16px;
    border-radius: 100px;
    border: 1px solid var(--rule);
  }
  .map-toggle {
    background: var(--bone);
    border: 1px solid var(--rule);
    padding: 4px;
    border-radius: 100px;
    display: flex;
  }
  .map-toggle button {
    background: none;
    border: none;
    color: var(--ink-mid);
    padding: 5px 12px;
    border-radius: 100px;
    font-size: 11px;
    font-family: var(--mono);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
  }
  .map-toggle button.active { background: var(--ink); color: var(--bone); }
  .map-bottom {
    position: absolute;
    bottom: 22px; left: 22px; right: 22px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    z-index: 2;
  }
  .map-chip {
    background: var(--bone);
    border: 1px solid var(--rule);
    padding: 6px 13px;
    border-radius: 100px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 1.5px;
    color: var(--ink);
    cursor: pointer;
    transition: all 0.2s;
  }
  .map-chip.active { background: var(--clay); color: var(--bone); border-color: var(--clay); }
  .map-chip:not(.active):hover { border-color: var(--clay); color: var(--clay); }

  /* Listings */
  .listings-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 4px;
  }
  .listings-count {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 1.5px;
    color: var(--ink-soft);
    text-transform: uppercase;
  }
  .listings-count strong { color: var(--ink); }
  .listings-sort {
    background: none;
    border: none;
    color: var(--ink-mid);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
  }
  .listings-sort::after { content: " ⇅"; }

  .listing {
    padding: 22px 0;
    border-bottom: 1px solid var(--rule-soft);
    cursor: pointer;
    display: grid;
    grid-template-columns: 52px 1fr auto;
    gap: 16px;
    align-items: center;
    transition: padding-left 0.3s ease;
  }
  .listing:hover { padding-left: 8px; }
  .listing:hover .listing-arrow { transform: translateX(4px); opacity: 1; }

  /* Avatar — V2 import */
  .listing-avatar {
    width: 52px; height: 52px;
    border-radius: 50%;
    background: var(--linen);
    border: 1px solid var(--rule);
    overflow: hidden;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .listing-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .avatar-initial {
    font-family: var(--serif);
    font-style: italic;
    font-size: 22px;
    color: var(--clay);
    line-height: 1;
    font-variation-settings: "opsz" 72;
  }

  .listing-modality {
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: 6px;
    display: flex;
    align-items: center;
    gap: 0;
  }
  .listing-modality span:not(:last-child)::after { content: " · "; color: var(--ink-soft); margin: 0 4px; }
  .featured-tag {
    background: var(--linen-2);
    border-radius: 100px;
    padding: 2px 8px;
    font-size: 9px;
    color: var(--ochre);
    margin-left: 6px;
  }
  .listing-title {
    font-family: var(--serif);
    font-style: italic;
    font-size: 24px;
    color: var(--ink);
    line-height: 1.05;
    letter-spacing: -0.5px;
    margin-bottom: 4px;
    font-variation-settings: "opsz" 72;
  }
  .listing-by {
    font-family: var(--serif);
    font-style: italic;
    font-size: 13px;
    color: var(--ink-mid);
  }
  .listing-by strong { color: var(--ink); font-weight: 400; }

  .listing-right {
    text-align: right;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 3px;
    position: relative;
    padding-right: 18px;
  }
  .listing-arrow {
    position: absolute;
    right: 0; top: 4px;
    font-size: 16px;
    color: var(--clay);
    opacity: 0.4;
    transition: all 0.3s;
  }
  .listing-time {
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    color: var(--ink);
    font-variation-settings: "opsz" 72;
  }
  .listing-price {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 1px;
    color: var(--ink-soft);
  }
  .listing-price strong { color: var(--clay); font-weight: 500; }

  @media (max-width: 1024px) {
    .map-grid { grid-template-columns: 1fr; }
    .map-frame { aspect-ratio: 4/3; }
  }
</style>
