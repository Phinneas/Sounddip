---
// Topbar — sticky nav with scroll state
// Improvement: removed "Vol. I · Issue 24" label (was confusing as magazine).
// Now shows city + live session count left, logo center, nav right.
// Picks up frosted-bone backdrop on scroll (V2 pattern, V1 palette).
---

<header class="topbar" id="topbar">
  <div class="topbar-inner">
    <div class="topbar-left">
      <span class="city-signal">Los Angeles · <strong>20 sessions tracked</strong></span>
    </div>
    <a href="/" class="logo">Sound Dip</a>
    <nav class="topbar-right">
      <a href="/explore">Explore</a>
      <a href="/cities">Cities</a>
      <a href="/practitioners">Practitioners</a>
      <a href="/journal">Journal</a>
      <a href="/sign-in" class="pill">Sign in</a>
    </nav>
  </div>
</header>

<style>
  .topbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    border-bottom: 1px solid transparent;
    transition: background 0.35s ease, border-color 0.35s ease, backdrop-filter 0.35s ease;
  }
  /* Scrolled state — added via JS */
  .topbar.scrolled {
    background: rgba(244, 237, 224, 0.82);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-color: var(--rule);
  }
  .topbar-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 20px 6vw;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 32px;
    transition: padding 0.35s ease;
  }
  .topbar.scrolled .topbar-inner { padding: 14px 6vw; }

  .city-signal {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .city-signal strong { color: var(--ink); font-weight: 500; }

  .logo {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: 28px;
    color: var(--ink);
    letter-spacing: -0.5px;
    text-decoration: none;
    font-variation-settings: "opsz" 144;
    white-space: nowrap;
  }
  .logo::before {
    content: "≈";
    color: var(--clay);
    margin-right: 5px;
    font-style: normal;
  }

  .topbar-right {
    display: flex;
    justify-content: flex-end;
    gap: 28px;
    align-items: center;
  }
  .topbar-right a {
    color: var(--ink-mid);
    text-decoration: none;
    font-size: 13px;
    font-weight: 400;
    transition: color 0.2s;
  }
  .topbar-right a:hover { color: var(--clay); }
  .topbar-right .pill {
    padding: 7px 16px;
    border: 1px solid var(--ink);
    border-radius: 100px;
    font-size: 12px;
    color: var(--ink);
    transition: background 0.2s, color 0.2s;
  }
  .topbar-right .pill:hover { background: var(--ink); color: var(--bone); }

  @media (max-width: 1024px) {
    .topbar-right { display: none; }
    .topbar-inner { grid-template-columns: 1fr auto; }
    .city-signal { display: none; }
  }
</style>

<script>
  const topbar = document.getElementById('topbar');
  window.addEventListener('scroll', () => {
    topbar?.classList.toggle('scrolled', window.scrollY > 48);
  }, { passive: true });
</script>
