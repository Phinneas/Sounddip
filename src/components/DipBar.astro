---
// DipBar — the segmented search widget
// Improvements:
//   • Added chevron (⌄) after each field value — clear dropdown affordance
//   • Hover gives each field a deeper linen background
//   • Active field shows a thin clay underline
//   • Arrow icon changed to ↗ on submit to signal discovery action
---

<div class="dip-bar-wrap" id="dip-bar">
  <form class="dip-bar" onsubmit="event.preventDefault()">

    <div class="dip-field" tabindex="0">
      <div class="dip-label">City</div>
      <div class="dip-value">Brooklyn, NY <span class="chevron">⌄</span></div>
    </div>

    <div class="dip-field" tabindex="0">
      <div class="dip-label">When</div>
      <div class="dip-value">Tonight <span class="chevron">⌄</span></div>
    </div>

    <div class="dip-field" tabindex="0">
      <div class="dip-label">Time</div>
      <div class="dip-value placeholder">After 6 PM <span class="chevron">⌄</span></div>
    </div>

    <div class="dip-field" tabindex="0">
      <div class="dip-label">Modality</div>
      <div class="dip-value placeholder">Any <span class="chevron">⌄</span></div>
    </div>

    <button type="submit" class="dip-submit">
      Find sessions
    </button>

  </form>
</div>

<style>
  .dip-bar-wrap {
    max-width: 1440px;
    margin: 0 auto;
    padding: 56px 6vw 0;
    scroll-margin-top: 80px; /* offset for fixed topbar */
  }
  .dip-bar {
    background: var(--linen);
    border-radius: 16px;
    padding: 14px;
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr auto;
    gap: 1px;
    box-shadow: var(--shadow);
    border: 1px solid var(--rule-soft);
  }
  .dip-field {
    padding: 18px 26px;
    cursor: pointer;
    border-radius: 10px;
    position: relative;
    transition: background 0.2s;
    outline: none;
  }
  .dip-field:hover,
  .dip-field:focus { background: var(--bone-2); }
  /* Clay underline on focus — improved affordance */
  .dip-field:focus::after {
    content: "";
    position: absolute;
    bottom: 10px; left: 26px; right: 26px;
    height: 1px;
    background: var(--clay);
    opacity: 0.6;
  }
  /* Dividers between fields */
  .dip-field:not(:last-of-type)::before {
    content: "";
    position: absolute;
    right: -1px; top: 25%; bottom: 25%;
    width: 1px;
    background: var(--rule);
  }
  .dip-label {
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: 6px;
  }
  .dip-value {
    font-family: var(--serif);
    font-style: italic;
    font-size: 21px;
    color: var(--ink);
    letter-spacing: -0.5px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-variation-settings: "opsz" 72;
  }
  .dip-value.placeholder { color: var(--ink-soft); }
  .chevron {
    font-family: var(--sans);
    font-style: normal;
    font-size: 13px;
    color: var(--ink-soft);
    margin-top: 2px;
    flex-shrink: 0;
  }
  .dip-submit {
    background: var(--ink);
    color: var(--bone);
    border: none;
    padding: 0 36px;
    border-radius: 10px;
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    letter-spacing: 0.3px;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .dip-submit::after { content: "↗"; font-size: 15px; }
  .dip-submit:hover { background: var(--clay); }

  @media (max-width: 1024px) {
    .dip-bar { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 640px) {
    .dip-bar { grid-template-columns: 1fr; }
  }
</style>
