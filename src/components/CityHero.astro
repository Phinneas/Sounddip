---
import type { City } from '../data/cities';

interface Props {
  city: City;
}
const { city } = Astro.props;
---

<div class="city-hero">
  <div class="city-hero-inner">

    <!-- LEFT: text -->
    <div class="city-hero-text">
      <a href="/cities" class="city-breadcrumb">← All cities</a>
      <div class="city-hero-region">{city.region}</div>
      <h1 class="city-hero-name">{city.name}</h1>
      <p class="city-hero-tagline">{city.tagline}</p>
      <div class="city-hero-stats">
        <div class="stat">
          <span class="stat-value">{city.sessionCount}</span>
          <span class="stat-label">sessions tracked</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-value">{city.priceRange}</span>
          <span class="stat-label">typical range</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-value">Tier {city.tier}</span>
          <span class="stat-label">coverage</span>
        </div>
      </div>
    </div>

    <!-- RIGHT: image -->
    <div class="city-hero-photo-wrap">
      <img src={city.img} alt={city.imgAlt} loading="lazy" />
      <div class="city-hero-caption">
        <span class="place">{city.name}, {city.region}</span>
        <span>sounddip.com</span>
      </div>
    </div>

  </div>
</div>

<style>
  .city-hero {
    max-width: 1440px;
    margin: 0 auto;
    padding: 120px 6vw 80px;
  }
  .city-hero-inner {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 80px;
    align-items: end;
  }

  /* Breadcrumb */
  .city-breadcrumb {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--ink-soft);
    text-decoration: none;
    margin-bottom: 32px;
    transition: color 0.2s;
  }
  .city-breadcrumb:hover { color: var(--clay); }

  /* Region label */
  .city-hero-region {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: 16px;
  }

  /* City name */
  .city-hero-name {
    font-family: var(--serif);
    font-weight: 300;
    font-size: clamp(72px, 10vw, 160px);
    line-height: 0.88;
    letter-spacing: -4px;
    color: var(--ink);
    font-variation-settings: "opsz" 144;
    margin-bottom: 32px;
  }

  /* Tagline */
  .city-hero-tagline {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(17px, 1.8vw, 22px);
    color: var(--ink-mid);
    line-height: 1.4;
    max-width: 480px;
    margin-bottom: 52px;
    font-variation-settings: "opsz" 72;
  }

  /* Stats row */
  .city-hero-stats {
    display: flex;
    align-items: stretch;
    border-top: 1px solid var(--rule);
    padding-top: 28px;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-right: 32px;
  }
  .stat-divider {
    width: 1px;
    background: var(--rule);
    margin-right: 32px;
    flex-shrink: 0;
  }
  .stat-value {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 22px;
    color: var(--ink);
    letter-spacing: -0.5px;
    font-variation-settings: "opsz" 72;
  }
  .stat-label {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  /* Photo */
  .city-hero-photo-wrap {
    position: relative;
    aspect-ratio: 4/5;
    border-radius: 6px;
    overflow: hidden;
    box-shadow: var(--shadow);
  }
  .city-hero-photo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .city-hero-caption {
    position: absolute;
    bottom: 20px;
    left: 20px;
    right: 20px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(244, 237, 224, 0.65);
  }
  .city-hero-caption .place {
    font-family: var(--serif);
    font-style: italic;
    font-size: 15px;
    text-transform: none;
    letter-spacing: -0.2px;
    color: var(--bone);
  }

  @media (max-width: 1024px) {
    .city-hero-inner { grid-template-columns: 1fr; gap: 48px; }
    .city-hero-name { font-size: clamp(60px, 14vw, 96px); }
    .city-hero-photo-wrap { aspect-ratio: 4/3; }
  }
</style>
