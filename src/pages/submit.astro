---
import Layout from '../layouts/Layout.astro';
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/JsonLd.astro';
import { cities } from '../data/cities';
---

<Layout
  title="Submit Your Sound Bath Practice — Sound Dip"
  description="Are you a sound bath practitioner? Add your practice to Sound Dip. Free, takes 2 minutes."
  canonical="/submit"
>
  <JsonLd data={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Submit Your Sound Bath Practice",
    "description": "Add your sound bath practice to the Sound Dip directory. Free listing for verified practitioners.",
    "url": "https://sounddip.com/submit"
  }} />

  <main>
    <Topbar />

    <section class="section">
      <div class="section-head">
        <div class="section-num">*</div>
        <div class="section-title">Add your <em>practice.</em></div>
        <div class="section-meta">
          <strong>Free listing</strong>
          takes 2 min
        </div>
      </div>
      <p class="section-lede">Sound Dip lists vetted sound bath practitioners across the US. If you run sessions, you belong here. Fill out the form below and we'll verify and publish your listing — usually within 48 hours.</p>

      <div class="form-container">
        <form id="submit-form" class="submit-form" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="name" class="form-label">Your name / Practice name <span class="required">*</span></label>
              <input type="text" id="name" name="name" required placeholder="e.g. Jamie Bechtold or The Soundbath Center" autocomplete="name" />
              <span class="form-hint">As you'd want it displayed on the site</span>
            </div>
            <div class="form-group">
              <label for="email" class="form-label">Your email <span class="required">*</span></label>
              <input type="email" id="email" name="email" required placeholder="you@example.com" autocomplete="email" />
              <span class="form-hint">We'll send a confirmation link to verify you're real</span>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="city" class="form-label">City <span class="required">*</span></label>
              <select id="city" name="city" required>
                <option value="">Select your city</option>
                {cities.map((c) => (
                  <option value={c.slug}>{c.name}, {c.region}</option>
                ))}
                <option value="other">My city isn't listed</option>
              </select>
            </div>
            <div class="form-group">
              <label for="neighborhood" class="form-label">Neighborhood / Area</label>
              <input type="text" id="neighborhood" name="neighborhood" placeholder="e.g. Eagle Rock, Silver Lake" />
              <span class="form-hint">Helps people find you in big cities</span>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="modality" class="form-label">Primary modality <span class="required">*</span></label>
              <select id="modality" name="modality" required>
                <option value="">Select your main instrument/style</option>
                <option value="gong">Gong</option>
                <option value="crystal">Crystal singing bowls</option>
                <option value="voice">Voice / vocal toning</option>
                <option value="brass">Brass / bronze bowls</option>
                <option value="tibetan-bowls">Tibetan / Himalayan bowls</option>
                <option value="reiki">Reiki + sound</option>
                <option value="breathwork">Breathwork + sound</option>
                <option value="mixed">Mixed / multi-instrument</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="form-group">
              <label for="website" class="form-label">Your website / booking URL <span class="required">*</span></label>
              <input type="url" id="website" name="website" required placeholder="https://yoursite.com" />
              <span class="form-hint">We'll cross-check this to verify your practice exists</span>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="instagram" class="form-label">Instagram (optional)</label>
              <input type="text" id="instagram" name="instagram" placeholder="@yourpractice" />
              <span class="form-hint">Helps us confirm you're active</span>
            </div>
            <div class="form-group">
              <label for="price" class="form-label">Typical session price</label>
              <input type="text" id="price" name="price" placeholder='e.g. "$25", "Sliding scale $20-40"' />
            </div>
          </div>

          <div class="form-group form-group--full">
            <label for="description" class="form-label">Describe your sessions <span class="required">*</span></label>
            <textarea id="description" name="description" required rows="4" placeholder="What happens in a typical session? What instruments do you use? What makes your practice distinctive? (2-3 sentences is fine)"></textarea>
          </div>

          <div class="form-group form-group--full">
            <label class="form-checkbox">
              <input type="checkbox" id="confirm" name="confirm" required />
              <span>I confirm this is a real, active sound bath practice and the information above is accurate.</span>
            </label>
          </div>

          <div class="form-actions">
            <button type="submit" class="submit-btn" id="submit-btn">
              <span class="btn-text">Submit for review</span>
              <span class="btn-loading" style="display:none">Submitting…</span>
            </button>
            <p class="form-disclaimer">Your listing will appear as "pending verification" until we confirm it. We check your website, Instagram, or Google listing — usually within 48 hours.</p>
          </div>

          <div id="form-success" class="form-success" style="display:none">
            <h3>Submitted.</h3>
            <p>Check your email for a confirmation link. Once you click it, your listing enters our review queue. We'll verify your practice against your website or social presence and publish it — typically within 48 hours.</p>
            <a href="/" class="back-home">Back to Sound Dip</a>
          </div>

          <div id="form-error" class="form-error" style="display:none">
            <h3>Something went wrong.</h3>
            <p id="error-message">Please try again. If the problem persists, email us at hello@sounddip.com.</p>
          </div>
        </form>
      </div>
    </section>

    <Footer />
  </main>
</Layout>

<style>
  /* ── Form layout ── */
  .form-container {
    max-width: 840px;
  }

  .submit-form {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-group--full {
    width: 100%;
  }

  /* ── Labels ── */
  .form-label {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--ink-mid);
  }

  .required {
    color: var(--clay);
  }

  .form-hint {
    font-size: 12px;
    color: var(--ink-soft);
    font-style: italic;
    margin-top: 2px;
  }

  /* ── Inputs ── */
  .submit-form input[type="text"],
  .submit-form input[type="email"],
  .submit-form input[type="url"],
  .submit-form select,
  .submit-form textarea {
    font-family: var(--sans);
    font-size: 15px;
    color: var(--ink);
    background: var(--bone-2);
    border: 1px solid var(--rule);
    border-radius: 8px;
    padding: 14px 16px;
    transition: border-color 0.2s, box-shadow 0.2s;
    width: 100%;
  }

  .submit-form input:focus,
  .submit-form select:focus,
  .submit-form textarea:focus {
    outline: none;
    border-color: var(--clay);
    box-shadow: 0 0 0 3px rgba(154, 90, 57, 0.12);
  }

  .submit-form input:invalid:not(:focus):not(:placeholder-shown),
  .submit-form select:invalid:not(:focus) {
    border-color: var(--clay-d);
  }

  .submit-form textarea {
    resize: vertical;
    min-height: 100px;
  }

  .submit-form select {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%2375685a' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 16px center;
    padding-right: 40px;
  }

  /* ── Checkbox ── */
  .form-checkbox {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    cursor: pointer;
    font-size: 14px;
    color: var(--ink-mid);
    line-height: 1.5;
  }

  .form-checkbox input[type="checkbox"] {
    width: 18px;
    height: 18px;
    min-width: 18px;
    margin-top: 2px;
    accent-color: var(--clay);
    cursor: pointer;
  }

  /* ── Submit button ── */
  .submit-btn {
    font-family: var(--sans);
    font-size: 15px;
    font-weight: 500;
    color: var(--bone);
    background: var(--ink);
    border: none;
    border-radius: 100px;
    padding: 16px 40px;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
  }

  .submit-btn:hover {
    background: var(--ink-mid);
  }

  .submit-btn:active {
    transform: scale(0.98);
  }

  .submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .form-actions {
    display: flex;
    align-items: flex-start;
    gap: 32px;
  }

  .form-disclaimer {
    font-size: 13px;
    color: var(--ink-soft);
    max-width: 380px;
    line-height: 1.5;
  }

  /* ── Success / Error ── */
  .form-success,
  .form-error {
    padding: 40px;
    border-radius: 12px;
    max-width: 840px;
  }

  .form-success {
    background: var(--linen);
    border: 1px solid var(--sand);
  }

  .form-success h3 {
    font-family: var(--serif);
    font-weight: 300;
    font-size: 36px;
    color: var(--ink);
    margin-bottom: 16px;
    font-variation-settings: "opsz" 72;
  }

  .form-success p {
    color: var(--ink-mid);
    font-size: 16px;
    line-height: 1.6;
    margin-bottom: 24px;
  }

  .back-home {
    display: inline-block;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--clay);
    text-decoration: none;
    border-bottom: 1px solid var(--clay);
    padding-bottom: 2px;
    transition: color 0.2s;
  }

  .back-home:hover {
    color: var(--clay-d);
  }

  .form-error {
    background: rgba(154, 90, 57, 0.06);
    border: 1px solid rgba(154, 90, 57, 0.2);
  }

  .form-error h3 {
    font-family: var(--serif);
    font-weight: 300;
    font-size: 28px;
    color: var(--clay-d);
    margin-bottom: 12px;
  }

  .form-error p {
    color: var(--ink-mid);
    font-size: 15px;
    line-height: 1.5;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .form-row { grid-template-columns: 1fr; gap: 24px; }
    .form-actions { flex-direction: column; gap: 16px; }
    .section { padding: 100px 5vw 0; }
  }

  @media (max-width: 640px) {
    .section { padding: 80px 4vw 0; }
  }
</style>

<script>
  const form = document.getElementById('submit-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = submitBtn.querySelector('.btn-text') as HTMLElement;
  const btnLoading = submitBtn.querySelector('.btn-loading') as HTMLElement;
  const successEl = document.getElementById('form-success') as HTMLElement;
  const errorEl = document.getElementById('form-error') as HTMLElement;
  const errorMsg = document.getElementById('error-message') as HTMLElement;

  const CMS_API = 'https://sounddip-cms.buzzuw2.workers.dev';

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Client-side validation
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const data = new FormData(form);
    const name = data.get('name') as string;
    const email = data.get('email') as string;
    const citySlug = data.get('city') as string;
    const neighborhood = data.get('neighborhood') as string;
    const modality = data.get('modality') as string;
    const website = data.get('website') as string;
    const instagram = data.get('instagram') as string;
    const price = data.get('price') as string;
    const description = data.get('description') as string;

    // Show loading state
    submitBtn.disabled = true;
    btnText.style.display = 'none';
    btnLoading.style.display = 'inline';

    try {
      // Step 1: Look up the city ID from Payload
      const cityRes = await fetch(`${CMS_API}/api/cities?where[slug][equals]=${encodeURIComponent(citySlug)}&limit=1`);
      if (!cityRes.ok) throw new Error('Failed to look up city');
      const cityData = await cityRes.json();

      if (!cityData.docs?.[0]?.id && citySlug !== 'other') {
        throw new Error('City not found in our directory. Please select a valid city.');
      }

      const cityId = cityData.docs?.[0]?.id;

      // Step 2: Generate a slug from the name
      const slug = name
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-|-$/g, '')
        + '-' + citySlug;

      // Step 3: Create the listing as draft + needs-verification
      const listingPayload: Record<string, any> = {
        name,
        slug,
        city: cityId,
        neighborhood: neighborhood || undefined,
        modalityTags: [modality],
        modalityDescription: modality,
        bookingUrl: website,
        practitionerBio: description,
        sessionDescription: description,
        price: price || 'Not published',
        source: 'Self-submitted via /submit form',
        listingStatus: 'needs-verification',
        _status: 'draft',
        // Store verification metadata in sourcingNotes
        sourcingNotes: `Self-submission | email: ${email}${instagram ? ' | instagram: ' + instagram : ''} | Pending verification`,
      };

      // If city isn't listed, note that
      if (citySlug === 'other') {
        listingPayload.sourcingNotes += ' | City not in current directory';
        delete listingPayload.city; // Remove city reference if not found
      }

      const createRes = await fetch(`${CMS_API}/api/listings`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(listingPayload),
      });

      if (!createRes.ok) {
        const errBody = await createRes.text();
        throw new Error(`Failed to create listing: ${errBody}`);
      }

      // Step 4: Send verification email via the CMS endpoint
      try {
        await fetch(`${CMS_API}/api/submit-verify`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, name, slug }),
        });
      } catch {
        // Email sending failure shouldn't block the form — admin can verify manually
      }

      // Show success
      form.style.display = 'none';
      successEl.style.display = 'block';

    } catch (err: any) {
      // Show error
      errorMsg.textContent = err.message || 'Something went wrong. Please try again.';
      errorEl.style.display = 'block';
      setTimeout(() => { errorEl.style.display = 'none'; }, 8000);
    } finally {
      submitBtn.disabled = false;
      btnText.style.display = 'inline';
      btnLoading.style.display = 'none';
    }
  });
</script>
