---
import { getCityBySlug, cities } from '../../data/cities';
import Layout from '../../layouts/Layout.astro';
import Topbar from '../../components/Topbar.astro';
import CityHero from '../../components/CityHero.astro';
import VenueCard from '../../components/VenueCard.astro';
import ListingCard from '../../components/ListingCard.astro';
import Footer from '../../components/Footer.astro';
import JsonLd from '../../components/JsonLd.astro';

export function getStaticPaths() {
  return cities.map((city) => ({
    params: { city: city.slug },
  }));
}

const { city: slug } = Astro.params;
const city = getCityBySlug(slug!);
if (!city) return Astro.redirect('/');

const pageTitle = `Best Sound Baths in ${city.name} — Sound Dip`;
const pageDescription = `${city.sessionCount} vetted sound bath sessions in ${city.name}. ${city.tagline}`;
const sceneParagraphs = city.scene.split('\n\n').filter(Boolean);

// Fetch listings from Payload CMS at build time
let listings: any[] = [];
const CMS_API = 'https://sounddip-cms.buzzuw2.workers.dev';
try {
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 10000);
  const cityRes = await fetch(`${CMS_API}/api/cities?where[slug][equals]=${city.slug}&limit=1`, { signal: controller.signal });
  clearTimeout(timeout);
  const cityData = await cityRes.json();
  if (cityData.docs?.[0]?.id) {
    const cityId = cityData.docs[0].id;
    const controller2 = new AbortController();
    const timeout2 = setTimeout(() => controller2.abort(), 15000);
    const listingsRes = await fetch(`${CMS_API}/api/listings?where[city][equals]=${cityId}&limit=100&depth=0`, { signal: controller2.signal });
    clearTimeout(timeout2);
    const listingsData = await listingsRes.json();
    listings = listingsData.docs || [];
  }
} catch (e) {
  // API fetch failed or timed out — listings section will be empty
}

// Only show active and active-secondary listings, sorted by status
const visibleListings = listings
  .filter((l: any) => ['active', 'active-secondary'].includes(l.listingStatus))
  .sort((a: any, b: any) => {
    const statusOrder: Record<string, number> = { 'active': 0, 'active-secondary': 1 };
    return (statusOrder[a.listingStatus] ?? 9) - (statusOrder[b.listingStatus] ?? 9);
  });
---

<Layout title={pageTitle} description={pageDescription} canonical={`/cities/${city.slug}`}>
  <JsonLd data={{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://sounddip.com"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": city.name,
        "item": `https://sounddip.com/cities/${city.slug}`
      }
    ]
  }} />
  <JsonLd data={{
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": `Sound Bath Sessions in ${city.name}`,
    "description": `${city.sessionCount} vetted sound bath sessions in ${city.name}. ${city.tagline}`,
    "numberOfItems": city.venues.length,
    "itemListElement": city.venues.map((venue, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": venue.name,
      "description": venue.note
    }))
  }} />
  <main>
    <Topbar />
    <CityHero city={city} />

    <!-- i. The scene -->
    <section class="section">
      <div class="section-head">
        <div class="section-num">i.</div>
        <div class="section-title">The <em>scene.</em></div>
        <div class="section-meta">
          <strong>{city.name}</strong>
          {city.region}
        </div>
      </div>
      <div class="scene-body">
        {sceneParagraphs.map((para) => (
          <p class="scene-para">{para}</p>
        ))}
      </div>
    </section>

    <!-- ii. Where to go -->
    <section class="section">
      <div class="section-head">
        <div class="section-num">ii.</div>
        <div class="section-title">Where to <em>go.</em></div>
        <div class="section-meta">
          <strong>{city.venues.length} venues</strong>
          curated
        </div>
      </div>
      <p class="section-lede">The places in {city.name} worth showing up for — vetted, not aggregated.</p>
      <div class="venues-list">
        {city.venues.map((venue, i) => (
          <VenueCard name={venue.name} note={venue.note} index={i} />
        ))}
      </div>
    </section>

    {visibleListings.length > 0 && (
    <section class="section">
      <div class="section-head">
        <div class="section-num">ii-b.</div>
        <div class="section-title">All <em>sessions.</em></div>
        <div class="section-meta">
          <strong>{visibleListings.length} listings</strong>
          in {city.name}
        </div>
      </div>
      <p class="section-lede">Every vetted practitioner and session in {city.name} — click a name to read more, book directly through their site.</p>
      <div class="listings-list">
        {visibleListings.map((listing: any, i: number) => (
          <ListingCard
            name={listing.name}
            slug={listing.slug}
            neighborhood={listing.neighborhood}
            modalityTags={listing.modalityTags}
            modalityDescription={listing.modalityDescription}
            duration={listing.duration}
            price={listing.price}
            bookingUrl={listing.bookingUrl}
            practitionerBio={listing.practitionerBio}
            sessionDescription={listing.sessionDescription}
            listingStatus={listing.listingStatus}
            photo={listing.photo}
            index={i}
          />
        ))}
      </div>
    </section>
    )}

    <!-- iii. Your first dip -->
    <section class="section section--last">
      <div class="section-head">
        <div class="section-num">iii.</div>
        <div class="section-title">Your first <em>dip.</em></div>
        <div class="section-meta">
          <strong>Beginner's guide</strong>
          {city.name}
        </div>
      </div>
      <p class="section-lede">{city.beginner}</p>

      <div class="meta-grid">
        <div class="meta-block">
          <div class="meta-label">Formats available</div>
          <div class="formats-list">
            {city.formats.map((f) => (
              <span class="format-pill">{f}</span>
            ))}
          </div>
        </div>
        <div class="meta-block">
          <div class="meta-label">Typical price</div>
          <div class="price-display">{city.priceRange}</div>
          <p class="price-note">per session, walk-in or booked</p>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</Layout>

<style>
  main { position: relative; z-index: 2; }

  /* ── Scene ── */
  .scene-body {
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .scene-para {
    font-family: var(--serif);
    font-size: 18px;
    line-height: 1.75;
    color: var(--ink-mid);
    font-variation-settings: "opsz" 72;
  }

  /* ── Venues ── */
  .venues-list {
    max-width: 920px;
  }

  /* ── Listings ── */
  .listings-list {
    max-width: 920px;
  }

  /* ── First dip ── */
  .section--last {
    padding-bottom: 140px;
  }
  .meta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    max-width: 920px;
  }
  .meta-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 20px;
  }
  .formats-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .format-pill {
    font-family: var(--sans);
    font-size: 13px;
    color: var(--ink);
    background: var(--bone-2);
    border: 1px solid var(--rule);
    border-radius: 100px;
    padding: 8px 18px;
    transition: border-color 0.2s, color 0.2s;
    cursor: default;
    user-select: none;
  }
  .format-pill:hover {
    border-color: var(--clay);
    color: var(--clay);
  }
  .price-display {
    font-family: var(--serif);
    font-weight: 300;
    font-size: 52px;
    color: var(--ink);
    letter-spacing: -2px;
    line-height: 1;
    margin-bottom: 12px;
    font-variation-settings: "opsz" 72;
  }
  .price-note {
    font-family: var(--serif);
    font-style: italic;
    font-size: 15px;
    color: var(--ink-soft);
    font-variation-settings: "opsz" 72;
  }

  @media (max-width: 1024px) {
    .meta-grid { grid-template-columns: 1fr; gap: 40px; }
  }
</style>
