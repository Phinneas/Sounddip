---
import Layout from '../layouts/Layout.astro';
import Topbar from '../components/Topbar.astro';
import Hero from '../components/Hero.astro';
import DipBar from '../components/DipBar.astro';
import MapSection from '../components/MapSection.astro';
import FeaturedSection from '../components/FeaturedSection.astro';
import CitiesSection from '../components/CitiesSection.astro';
import FirstDip from '../components/FirstDip.astro';
import Currents from '../components/Currents.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/JsonLd.astro';
---

<JsonLd data={{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Sound Dip",
  "url": "https://sounddip.com",
  "description": "Discover curated sound bath sessions in your city. Browse practitioners, book your next immersion, and explore the world of sound healing.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://sounddip.com/cities/{search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}} />

<!-- Organization schema for knowledge panel eligibility -->
<JsonLd data={{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Sound Dip",
  "url": "https://sounddip.com",
  "description": "A curated directory of sound bath sessions, practitioners, and venues across the United States.",
  "sameAs": []
}} />

<!-- FAQPage schema: top-level "what is a sound bath" Q&A -->
<JsonLd data={{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a sound bath?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A sound bath is a meditative experience where you lie down and close your eyes while vibrations from singing bowls, gongs, and voice wash over you for about an hour. Most people fall asleep at least a little — that's the point. No movement, chanting, or effort is required."
      }
    },
    {
      "@type": "Question",
      "name": "What should I bring to a sound bath?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Arrive ten minutes early — most spaces lock the door once the session begins. Bring socks, a water bottle, and an open mind. Mats and blankets are typically provided."
      }
    },
    {
      "@type": "Question",
      "name": "How much does a sound bath cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Group sound bath sessions in most US cities range from $20 to $60 per session. Private sessions can run $100–$300 depending on the practitioner and duration. Walk-in and advance booking prices are usually similar."
      }
    }
  ]
}} />

<Layout
  title="Sound Dip — Find a Sound Bath Near You"
  description="Discover curated sound bath sessions in your city. Browse practitioners, book your next immersion, and explore the world of sound healing."
>
  <Topbar />
  <main>
    <Hero />
    <DipBar />
    <div class="page-sections">
      <MapSection />
      <FeaturedSection />
      <CitiesSection />
      <FirstDip />
    </div>
    <Currents />
    <div class="submit-banner">
      <a href="/submit">Run sound bath sessions? <em>Add your practice — free.</em></a>
    </div>
  </main>
  <Footer />
</Layout>

<style is:global>
  .page-sections {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 6vw;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  /* Each section inside page-sections gets vertical spacing */
  .page-sections .section {
    padding-top: 120px;
    padding-bottom: 120px;
    border-bottom: 1px solid var(--rule-soft);
  }
  .page-sections .section:last-child { border-bottom: none; }

  /* ── Submit banner ── */
  .submit-banner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 60px 6vw 100px;
    text-align: center;
  }
  .submit-banner a {
    font-family: var(--serif);
    font-style: italic;
    font-size: 22px;
    color: var(--clay);
    text-decoration: none;
    border-bottom: 1px solid var(--clay);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
    font-variation-settings: "opsz" 72;
  }
  .submit-banner a em { font-style: italic; }
  .submit-banner a:hover {
    color: var(--clay-d);
    border-color: var(--clay-d);
  }
</style>
